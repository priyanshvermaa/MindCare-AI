            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Dealing with Exam Stress\",\n  \"content\": \"I have been using 4-7-8 breathing exercises before tests. It really helps lower my heart rate!\",\n  \"category\": \"Student Life\",\n  \"anonymous\": false\n}"
